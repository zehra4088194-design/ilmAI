# Copy values into Coolify's Environment Variables screen. Do not commit real secrets.

# Public app/domain. HTTPS is required for camera, PWA installation, and Play Store TWA.
NEXT_PUBLIC_SITE_URL=https://your-domain.example
NEXT_PUBLIC_APP_URL=https://your-domain.example
NEXT_PUBLIC_APP_NAME=ilm AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# Existing managed Supabase project. Keep Service Role server-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# Generate independent random alphanumeric values, at least 32 characters each.
AI_GATEWAY_SECRET=replace-with-a-long-random-secret
OCR_SERVICE_SECRET=replace-with-a-different-long-random-secret
VALKEY_PASSWORD=replace-with-a-long-url-safe-password
CRON_SECRET=replace-with-a-different-long-random-secret
ADMIN_EMAILS=you@example.com

# Existing analytics plus optional monitoring. All can remain empty initially.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_ENVIRONMENT=production

# Optional Firebase Cloud Messaging. Oracle requires the base64 service account.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Optional R2 offload and Algolia public catalog search.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ilm-ai-assets
ALGOLIA_ENABLED=false
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_API_KEY=
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_INDEX_NAME=ilm_ai_public_catalog

# Provider pools stay only inside the private Oracle AI gateway container.
GROQ_API_KEYS_JSON=[]
GROK_API_KEYS_JSON=[]
CLAUDE_API_KEYS_JSON=[]
GPT_API_KEYS_JSON=[]
GEMINI_API_KEYS_JSON=[]
OCRSPACE_API_KEYS_JSON=[]
OPENROUTER_API_KEYS_JSON=[]
GEMINI_LIVE_MODEL=
GEMINI_VISION_MODEL=

# Self-hosted OCR limits. Printed scans use Tesseract/OCRmyPDF; handwriting uses Gemini first.
OCR_LANGUAGES=eng+urd
OCR_MAX_FILE_BYTES=26214400
OCR_MAX_PDF_PAGES=30
OCR_MAX_CONCURRENT_JOBS=1
OCR_JOB_TIMEOUT_SECONDS=180

# Oracle Email Delivery SMTP. Configure the same SMTP details in Supabase Auth.
SMTP_HOST=smtp.email.YOUR_OCI_REGION.oci.oraclecloud.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-oracle-smtp-username
SMTP_PASSWORD=your-oracle-smtp-password
EMAIL_FROM=ilm AI <noreply@your-domain.example>

# Payments remain optional until merchant approval. Android in-app purchases need Play Billing.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_PRICE_ID_PRO_MONTHLY=
PADDLE_PRICE_ID_PRO_ANNUAL=
PADDLE_PRICE_ID_ELITE_MONTHLY=
PADDLE_PRICE_ID_ELITE_ANNUAL=

# Optional Pakistan local checkout. Keep empty until PayPro merchant plan IDs
# and webhook secret are confirmed from your approved merchant account.
PAYPRO_CHECKOUT_URL=
PAYPRO_WEBHOOK_SECRET=
PAYPRO_PLAN_ID_PRO_MONTHLY=
PAYPRO_PLAN_ID_PRO_ANNUAL=
PAYPRO_PLAN_ID_ELITE_MONTHLY=
PAYPRO_PLAN_ID_ELITE_ANNUAL=

# Free web ads only. Do not assume website AdSense is valid inside the Play app.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=

# Fill after Play App Signing provides the SHA-256 certificate fingerprint.
ANDROID_PACKAGE_NAME=study.ilm.app
ANDROID_SHA256_CERT_FINGERPRINTS=
# Attach this hostname to the same Coolify web service; checkout is blocked there.
PLAY_CONSUMPTION_ONLY_HOSTS=app.your-domain.example
