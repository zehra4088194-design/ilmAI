# ============================================
# STUDYVERSE AI - ENVIRONMENT VARIABLES (Next.js app)
# ============================================
# NOTE: Raw AI/OCR provider keys (Groq, Claude, GPT, Gemini, OCR.space) do
# NOT go here. They live ONLY in the Cloudflare Worker (cloudflare-worker/worker.js).
# This app only needs the gateway URL + shared secret below.
# Full instructions: "StudyVerse AI - Deployment Guide.docx"

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# --- AI GATEWAY (Cloudflare Worker — holds all AI/OCR keys) ---
AI_GATEWAY_URL=https://studyverse-ai1.noorhusnain791.workers.dev
AI_GATEWAY_SECRET=paste_the_same_long_random_string_you_set_as_GATEWAY_SECRET_in_cloudflare

# --- STRIPE (Payments) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_ID_PRO_MONTHLY=price_your_id
STRIPE_PRICE_ID_PRO_ANNUAL=price_your_id

# --- UPSTASH REDIS (Rate Limiting — daily AI/quiz/OCR quotas) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# --- ADMIN ---
# Comma-separated list of emails allowed into /admin
ADMIN_EMAILS=you@example.com

# --- GOOGLE ADSENSE (shown to FREE tier users only) ---
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=xxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=xxxxxxxxxx

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=StudyVerse AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# --- EMAIL (Resend) ---
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@studyverse.ai

# --- CRON JOBS ---
CRON_SECRET=any_long_random_string_for_cron_auth
