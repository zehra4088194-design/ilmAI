# ============================================
# ILM AI - ENVIRONMENT VARIABLES (Next.js app)
# ============================================
# NOTE: Raw Assistant/OCR provider keys (Claude, GPT, Gemini, OCR.space, etc.) do
# NOT go here. They live ONLY in the Cloudflare Worker (cloudflare-worker/worker.js).
# This app only needs the gateway URL + shared secret below.
# Full instructions: "ilm AI - Deployment Guide.docx"

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# --- AI GATEWAY (Cloudflare Worker — holds all AI/OCR keys) ---
AI_GATEWAY_URL=https://ilm-ai1.noorhusnain791.workers.dev
AI_GATEWAY_SECRET=paste_the_same_long_random_string_you_set_as_GATEWAY_SECRET_in_cloudflare

# --- PAYMENTS ---
# Payments go through the provider-agnostic abstraction in src/lib/payments/
# (see database/migrations/002_payments_provider_agnostic.sql — the old
# Stripe-only columns/vars were replaced by this dual-provider setup):
#   - INTERNATIONAL region -> Paddle (src/lib/payments/paddle.ts)
#   - PAKISTAN region      -> PayPro (src/lib/payments/paypro.ts)
# Both files run with safe placeholder responses if their keys are unset,
# so the app still builds/runs without live payment accounts.
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_your_paddle_client_side_token
PADDLE_PRICE_ID_PRO_MONTHLY=pri_01kwy057fj5g4bf6vhb47zm2n2
PADDLE_PRICE_ID_PRO_ANNUAL=pri_01kwy0acnzx8ravh4db5pfdn4w
PADDLE_PRICE_ID_ELITE_MONTHLY=pri_01kwy0ex6p2jtb0m2y15cbmt8t
PADDLE_PRICE_ID_ELITE_ANNUAL=pri_01kwy0fy2az5kvb6v1p0x80dt8
PAYPRO_API_KEY=your_paypro_api_key
PAYPRO_WEBHOOK_SECRET=your_paypro_webhook_secret
PAYPRO_CHECKOUT_URL=https://your-paypro-hosted-checkout-url.example

# --- UPSTASH REDIS (Rate Limiting — daily AI/quiz/OCR quotas) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# --- ADMIN ---
# Comma-separated list of emails allowed into /admin
ADMIN_EMAILS=you@example.com

# --- GOOGLE ADSENSE (shown to FREE tier users only) ---
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=xxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=xxxxxxxxxx

# --- APP CONFIG ---
# Canonical public URL for SEO/OpenGraph/sitemap. Use your production domain on Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ilm AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# --- EMAIL (Resend) ---
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@ilm.ai

# --- CRON JOBS ---
CRON_SECRET=any_long_random_string_for_cron_auth
