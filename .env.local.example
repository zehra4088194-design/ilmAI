# ============================================
# ilm AI - LOCAL NEXT.JS ENVIRONMENT
# ============================================
# Raw AI provider keys do not belong here. They live only in the private
# AI gateway service. Production values are configured in the deployment host.

# --- MANAGED SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# --- PRIVATE SERVICES ---
AI_GATEWAY_URL=http://localhost:8787
AI_GATEWAY_SECRET=paste_the_same_long_random_string_used_by_the_ai_gateway
OCR_SERVICE_URL=http://localhost:8000
OCR_SERVICE_SECRET=paste_a_different_long_random_string_used_by_the_ocr_service
REDIS_URL=redis://:your-password@localhost:6379/0

# --- PAYMENTS (OPTIONAL UNTIL MERCHANT APPROVAL) ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_PRICE_ID_PRO_MONTHLY=
PADDLE_PRICE_ID_PRO_ANNUAL=
PADDLE_PRICE_ID_ELITE_MONTHLY=
PADDLE_PRICE_ID_ELITE_ANNUAL=

# --- ADMIN ---
ADMIN_EMAILS=you@example.com

# --- GOOGLE ADSENSE (FREE WEB USERS ONLY) ---
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-4877865173601332
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=

# --- APP CONFIG ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ilm AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# --- EMAIL SMTP ---
SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=ilm AI <noreply@your-domain.example>

# --- CRON ---
CRON_SECRET=replace_with_a_long_random_string

# --- GOOGLE PLAY / TRUSTED WEB ACTIVITY ---
ANDROID_PACKAGE_NAME=study.ilm.app
ANDROID_SHA256_CERT_FINGERPRINTS=
PLAY_CONSUMPTION_ONLY_HOSTS=
